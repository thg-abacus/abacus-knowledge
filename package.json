    "minisearch": "^7.2.0",
    "pdfjs-dist": "^5.7.284",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.0"
  }
