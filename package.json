{
  "name": "abacus-knowledge",
  "version": "1.0.0",
  "description": "MCP Knowledge Server for ABACUS ecosystem documentation RAG.",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "dev:http": "tsx --watch src/index.ts --http",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
